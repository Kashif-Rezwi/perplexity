# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=log
TRUST_PROXY=false
# Comma-separated exact origins. Leave empty when all browser traffic uses the
# frontend's same-origin /api proxy.
CORS_ORIGINS=http://localhost:3001

# PostgreSQL. Managed production databases normally require sslmode=require.
DATABASE_URL=postgresql://perplexity:change-me@localhost:5432/perplexity?schema=public

# Search (required)
TAVILY_API_KEY=tvly-dev-placeholder
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_SEARCH_TIMEOUT_MS=6000

# Active AI provider: openai or groq. Only the selected provider key is required.
AI_PROVIDER=openai

OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini
OPENAI_UTILITY_MODEL=gpt-4o-mini
OPENAI_ANSWER_TIMEOUT_MS=16000
OPENAI_QUERY_REWRITE_TIMEOUT_MS=6000
OPENAI_SUGGESTION_TIMEOUT_MS=15000

# GROQ_API_KEY=gsk-placeholder
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_UTILITY_MODEL=llama-3.1-8b-instant
# GROQ_ANSWER_TIMEOUT_MS=16000
# GROQ_QUERY_REWRITE_TIMEOUT_MS=6000
# GROQ_SUGGESTION_TIMEOUT_MS=15000
