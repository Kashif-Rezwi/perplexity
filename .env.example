# Docker Compose database. Use URL-safe credentials because they are inserted
# into DATABASE_URL by compose.yaml.
POSTGRES_DB=perplexity
POSTGRES_USER=perplexity
POSTGRES_PASSWORD=replace-with-a-long-random-local-password

# Backend runtime
LOG_LEVEL=log
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3001

# External services
TAVILY_API_KEY=tvly-dev-placeholder
AI_PROVIDER=openai
OPENAI_API_KEY=sk-placeholder
# GROQ_API_KEY=gsk-placeholder

# Optional overrides (the application has safe defaults)
# TAVILY_MAX_RESULTS=5
# TAVILY_SEARCH_DEPTH=basic
# TAVILY_SEARCH_TIMEOUT_MS=6000
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_UTILITY_MODEL=gpt-4o-mini
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_UTILITY_MODEL=llama-3.1-8b-instant
